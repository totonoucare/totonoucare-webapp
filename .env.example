# .env.example
# 実値は入れない。変数名の見本だけ。
# GitHubに本物のSecret Keyを保存しないこと。

# App URL
NEXT_PUBLIC_APP_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_RADAR_MODEL=
OPENAI_WEEKLY_REPORT_MODEL=
OPENAI_PERSONAL_KARTE_MODEL=
OPENAI_PERSONAL_KARTE_REASONING_EFFORT=
PERSONAL_KARTE_AI_ENABLED=

# Records / Ekken
# 公開期間・回数制限・モデル等の非機密設定は lib/records/policy.js で管理する。
# safety identifier専用の秘密値を分けたい場合だけ設定する。
# 未設定時は既存のSUPABASE_SERVICE_ROLE_KEYをハッシュ用secretとして利用する。
OPENAI_SAFETY_IDENTIFIER_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PERSONAL_KARTE_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# Cron / GitHub Actions
CRON_SECRET=
PROD_BASE_URL=

# Web Push / VAPID
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=

# Deprecated / legacy
# 古いコードに残っている可能性あり。今後は NEXT_PUBLIC_SUPABASE_URL に統一する。
SUPABASE_URL=

# Keep forecast based on constitution x weather only. Set true only for controlled legacy-feedback experiments.
RADAR_REVIEW_FEEDBACK_ENABLED=false

# Forecast v2 is the default. Set v1 only as an emergency rollback switch.
RADAR_FORECAST_MODEL_VERSION=v2
